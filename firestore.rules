rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isParticipant() {
      return signedIn() &&
        (resource.data.studentId == request.auth.uid ||
         resource.data.tutorId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) ||
        (signedIn() &&
         request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'ratingCount', 'ratingTotal', 'updatedAt']));
      allow delete: if false;
    }

    match /tutoringRequests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.studentId == request.auth.uid;
      allow update: if isParticipant();
      allow delete: if false;
    }

    match /tutoringSessions/{sessionId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.tutorId == request.auth.uid;
      allow update: if signedIn() &&
        (resource.data.studentId == request.auth.uid ||
         resource.data.tutorId == request.auth.uid);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if signedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          (
            request.resource.data.requestId is string &&
            exists(/databases/$(database)/documents/tutoringRequests/$(request.resource.data.requestId)) &&
            get(/databases/$(database)/documents/tutoringRequests/$(request.resource.data.requestId)).data.tutorId == request.auth.uid &&
            get(/databases/$(database)/documents/tutoringRequests/$(request.resource.data.requestId)).data.studentId == request.resource.data.userId
          ) ||
          (
            request.resource.data.requestId is string &&
            exists(/databases/$(database)/documents/tutoringRequests/$(request.resource.data.requestId)) &&
            get(/databases/$(database)/documents/tutoringRequests/$(request.resource.data.requestId)).data.studentId == request.auth.uid &&
            get(/databases/$(database)/documents/tutoringRequests/$(request.resource.data.requestId)).data.tutorId == request.resource.data.userId
          )
        );
      allow delete: if false;
    }

    match /availabilitySlots/{slotId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.studentId == request.auth.uid;
      allow update: if signedIn() &&
        (resource.data.studentId == request.auth.uid ||
         resource.data.tutorId == request.auth.uid);
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update, delete: if false;
    }

    match /habeasDataConsents/{consentId} {
      allow read, create, update: if isOwner(consentId);
      allow delete: if false;
    }
  }
}
